<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base app theme -->
    <style name="Theme.RecipeBook" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/watermelon_red</item>
        <item name="colorPrimaryVariant">@color/watermelon_dark_green</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/watermelon_green</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/watermelon_light</item>
        <item name="colorSurface">@color/white</item>
    </style>

    <!-- Toolbar style used across all activities -->
    <style name="Widget.RecipeBook.Toolbar" parent="Widget.MaterialComponents.Toolbar.Primary">
        <item name="android:background">@color/watermelon_red</item>
        <item name="titleTextColor">@color/white</item>
        <item name="navigationIconTint">@color/white</item>
    </style>

    <!-- Primary filled button (Save, Search, etc.) -->
    <style name="Widget.RecipeBook.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/watermelon_red</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
    </style>

    <!-- Outlined / secondary button (Delete, Cancel) -->
    <style name="Widget.RecipeBook.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/watermelon_red</item>
        <item name="android:textColor">@color/watermelon_red</item>
        <item name="cornerRadius">24dp</item>
    </style>

    <!-- Recipe card style -->
    <style name="Widget.RecipeBook.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="contentPadding">12dp</item>
    </style>

    <!-- TextInputLayout (form fields) -->
    <style name="Widget.RecipeBook.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/watermelon_red</item>
        <item name="hintTextColor">@color/watermelon_red</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <!-- Section header text (e.g. "Ingredients", "Steps") -->
    <style name="TextAppearance.RecipeBook.SectionHeader" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textColor">@color/watermelon_dark_green</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- Recipe title on cards -->
    <style name="TextAppearance.RecipeBook.CardTitle" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">15sp</item>
    </style>

    <!-- Small subtitle text (category, prep time) -->
    <style name="TextAppearance.RecipeBook.CardSubtitle" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
    </style>

</resources>
